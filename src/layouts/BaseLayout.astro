---
// -----------------------------------------------------------------------------
// BaseLayout.astro
// Document shell: meta, SEO/Open Graph, font loading, favicon, header + footer,
// and a tiny IntersectionObserver for CSS-only scroll reveals.
// -----------------------------------------------------------------------------
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';

export interface Props {
  title?: string;
  description?: string;
  /** Path for canonical/OG URL, e.g. '/resources'. Defaults to '/'. */
  path?: string;
}

const {
  title = site.seo.title,
  description = site.seo.description,
  path = '/',
} = Astro.props;

const canonical = new URL(path, Astro.site ?? 'https://strategycircle.in').toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#1c3362" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <!-- Add an OG image at public/og-image.png and reference it here when ready. -->

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon placeholder (SVG mark; replace with brand favicon later) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://assets.calendly.com" />
    <link rel="preconnect" href="https://calendly.com" />
    <link rel="dns-prefetch" href="https://assets.calendly.com" />
    <link rel="dns-prefetch" href="https://calendly.com" />
    <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" />

    <!-- Fonts: Inter + Inter Tight -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Inter+Tight:wght@500;600;700&display=swap"
    />
  </head>

  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <!-- Scroll reveal: adds .is-visible to [data-reveal] elements in view. -->
    <script>
      const reveals = document.querySelectorAll<HTMLElement>('[data-reveal]');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (reduce || !('IntersectionObserver' in window)) {
        reveals.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
        );
        reveals.forEach((el) => io.observe(el));
      }
    </script>
    <script src="https://assets.calendly.com/assets/external/widget.js" async></script>
    <script is:inline>
      document.addEventListener('click', function (event) {
        const link = event.target.closest('a[href^="https://calendly.com/"]');

        if (!link) return;

        const url = link.getAttribute('href');

        if (!url) return;

        // Preserve normal browser behavior for new tab/window clicks.
        if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || link.target === '_blank') {
          return;
        }

        // If Calendly is available, open the popup. If not, allow normal navigation.
        if (window.Calendly && typeof window.Calendly.initPopupWidget === 'function') {
          event.preventDefault();
          window.Calendly.initPopupWidget({ url });
        }
      });
    </script>
  </body>
</html>
