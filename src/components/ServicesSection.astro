---
// -----------------------------------------------------------------------------
// ServicesSection.astro
// "Services Framework" — eyebrow, heading, description, and a responsive
// 6-card bordered grid built from the services data file.
// -----------------------------------------------------------------------------
import { servicesSection, services } from '../data/services';
import SectionEyebrow from './SectionEyebrow.astro';
import ServiceCard from './ServiceCard.astro';
---

<section class="services section" id="services">
  <div class="container">
    <header class="services__head" data-reveal>
      <SectionEyebrow>{servicesSection.eyebrow}</SectionEyebrow>
      <h2>{servicesSection.heading}</h2>
      <p class="services__desc">{servicesSection.description}</p>
    </header>

    <div class="services__grid">
      {services.map((service, i) => (
        <div data-reveal style={`--reveal-delay: ${(i % 3) * 80}ms`}>
          <ServiceCard service={service} index={i} />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    background-color: var(--color-white);
  }
  .services__head {
    max-width: 56ch;
    margin-bottom: var(--space-2xl);
  }
  .services__desc {
    font-size: var(--fs-body-lg);
    color: var(--text-body);
    margin-top: var(--space-md);
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }
  /* make each grid item stretch so cards are equal height */
  .services__grid > div {
    display: flex;
  }
  .services__grid > div > :global(.service-card) {
    width: 100%;
  }

  @media (max-width: 980px) {
    .services__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .services__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
