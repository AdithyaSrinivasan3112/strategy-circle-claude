---
// -----------------------------------------------------------------------------
// Icon.astro
// Self-authored, dependency-free inline SVG icons (line style, currentColor).
// Stroke icons inherit `color`; the LinkedIn brand glyph is filled.
// Usage: <Icon name="cfo" /> or <Icon name="arrow-right" size={20} />
// -----------------------------------------------------------------------------
export interface Props {
  name: string;
  size?: number;
  class?: string;
}

const { name, size = 24, class: className } = Astro.props;

// Stroke-based glyphs (fill: none, stroke: currentColor)
const stroke: Record<string, string> = {
  // Difference pillars
  partner: '<circle cx="12" cy="8" r="3.6"/><path d="M4.5 20.5a7.5 7.5 0 0 1 15 0"/>',
  precision: '<circle cx="12" cy="12" r="8.5"/><circle cx="12" cy="12" r="4"/><circle cx="12" cy="12" r="0.6" fill="currentColor" stroke="none"/>',
  scale: '<path d="M4 20V13"/><path d="M10.5 20V9"/><path d="M17 20V5"/><path d="M3 20h18"/>',
  holistic: '<circle cx="9" cy="10" r="4.6"/><circle cx="15" cy="10" r="4.6"/><circle cx="12" cy="15" r="4.6"/>',

  // Services
  cfo: '<rect x="3" y="8" width="18" height="12" rx="2"/><path d="M8 8V6.5A2.5 2.5 0 0 1 10.5 4h3A2.5 2.5 0 0 1 16 6.5V8"/><path d="M3 13h18"/>',
  structuring: '<path d="M3 9l9-5 9 5"/><path d="M4 9v9M9 9v9M15 9v9M20 9v9"/><path d="M3 20h18"/>',
  diligence: '<circle cx="11" cy="11" r="6"/><path d="M20.5 20.5 16 16"/><path d="M8.6 11l1.8 1.8L14 9.2"/>',
  contract: '<path d="M6 3h8l4 4v14H6z"/><path d="M14 3v4h4"/><path d="M9 12h6M9 16h4"/>',
  investment: '<path d="M3 17l5.5-5.5 3.5 3.5L21 6"/><path d="M16 6h5v5"/>',
  dpdp: '<path d="M12 3l7 2.6v5c0 4.4-3 7.4-7 8.8-4-1.4-7-4.4-7-8.8v-5z"/><path d="M12 9.6v2.2"/><circle cx="12" cy="13.4" r="1.1" fill="currentColor" stroke="none"/>',

  // UI
  'arrow-right': '<path d="M5 12h13"/><path d="M13 6l6 6-6 6"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M4 7l8 6 8-6"/>',
  phone: '<path d="M6.5 4h3l1.2 4-2 1.4a11 11 0 0 0 5 5l1.4-2 4 1.2v3a2 2 0 0 1-2.2 2A16 16 0 0 1 4.5 6.2 2 2 0 0 1 6.5 4z"/>',
  'map-pin': '<path d="M12 21s7-5.6 7-11a7 7 0 1 0-14 0c0 5.4 7 11 7 11z"/><circle cx="12" cy="10" r="2.5"/>',
  external: '<path d="M14 4h6v6"/><path d="M20 4l-9 9"/><path d="M18 13v5a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h5"/>',
  menu: '<path d="M4 7h16M4 12h16M4 17h16"/>',
  close: '<path d="M6 6l12 12M18 6L6 18"/>',
};

// Filled brand glyph
const solid: Record<string, string> = {
  linkedin:
    '<path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.8 0 0 .78 0 1.74v20.52C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.74V1.74C24 .78 23.2 0 22.22 0z"/>',
};

const isSolid = name in solid;
const inner = solid[name] ?? stroke[name] ?? '';
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={isSolid ? 'currentColor' : 'none'}
  stroke={isSolid ? 'none' : 'currentColor'}
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  set:html={inner}
/>
