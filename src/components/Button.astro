---
// -----------------------------------------------------------------------------
// Button.astro
// Renders an <a> (when `href` is set) or <button>, styled by variant.
// Variants: primary (navy), accent (orange), ghost (outline), link (text+arrow).
// -----------------------------------------------------------------------------
import Icon from './Icon.astro';

export interface Props {
  href?: string;
  variant?: 'primary' | 'accent' | 'ghost' | 'ghost-light' | 'link';
  size?: 'md' | 'lg';
  withArrow?: boolean;
  newTab?: boolean;
  class?: string;
  ariaLabel?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  withArrow = false,
  newTab = false,
  class: className = '',
  ariaLabel,
} = Astro.props;

const Tag = href ? 'a' : 'button';
const rel = newTab ? 'noopener noreferrer' : undefined;
const target = newTab ? '_blank' : undefined;
const classes = `btn btn--${variant} btn--${size} ${className}`.trim();
---

<Tag
  class={classes}
  href={href}
  rel={rel}
  target={target}
  aria-label={ariaLabel}
>
  <span class="btn__label"><slot /></span>
  {withArrow && <Icon name="arrow-right" size={18} class="btn__arrow" />}
</Tag>

<style>
  .btn {
    --btn-gap: 0.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--btn-gap);
    font-family: var(--font-body);
    font-weight: 600;
    line-height: 1;
    text-align: center;
    border: 1px solid transparent;
    border-radius: var(--radius-pill);
    transition:
      background-color var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out),
      color var(--dur) var(--ease-out),
      transform var(--dur-fast) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
    white-space: nowrap;
  }

  .btn--md {
    font-size: var(--fs-small);
    padding: 0.7rem 1.25rem;
  }
  .btn--lg {
    font-size: var(--fs-body);
    padding: 0.95rem 1.6rem;
  }

  .btn__arrow {
    transition: transform var(--dur) var(--ease-out);
  }
  .btn:hover .btn__arrow {
    transform: translateX(3px);
  }

  /* Primary — navy */
  .btn--primary {
    background-color: var(--color-primary);
    color: var(--color-white);
    box-shadow: var(--shadow-sm);
  }
  .btn--primary:hover {
    background-color: var(--color-dark-blue);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  /* Accent — orange */
  .btn--accent {
    background-color: var(--color-secondary);
    color: var(--color-white);
    box-shadow: var(--shadow-sm);
  }
  .btn--accent:hover {
    background-color: #e06d16;
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  /* Ghost — outline on light backgrounds */
  .btn--ghost {
    background-color: transparent;
    color: var(--color-primary);
    border-color: var(--color-primary);
  }
  .btn--ghost:hover {
    background-color: var(--primary-tint-08);
  }

  /* Ghost on dark backgrounds */
  .btn--ghost-light {
    background-color: transparent;
    color: var(--color-white);
    border-color: var(--white-tint-60);
  }
  .btn--ghost-light:hover {
    border-color: var(--color-white);
    background-color: var(--white-tint-08);
  }

  /* Link — text with arrow, accent-coloured */
  .btn--link {
    padding: 0.25rem 0;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-secondary);
    font-weight: 600;
  }
  .btn--link:hover {
    color: #e06d16;
  }
</style>
